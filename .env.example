# Configuration locale — copier en .env et remplir avec les vraies valeurs.
# .env ne doit JAMAIS être committé (voir .gitignore).

# Base de données MariaDB / MySQL
DB_HOST=localhost
DB_NAME=c2586017c_ds
DB_USER=c2586017c_dsapp
DB_PASS=

# Sécurité — clé pour signer les sessions, etc. (32+ chars random)
